COMPOSE_PROJECT_NAME=underworld-chat

POSTGRES_DB=underworld
POSTGRES_USER=underworld
POSTGRES_PASSWORD=underworld
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=underworld-files
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

DJANGO_DEBUG=1
DJANGO_SECRET_KEY=replace-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DATABASE_URL=postgresql://underworld:underworld@postgres:5432/underworld
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
MASTER_ENCRYPTION_KEY=replace-with-32-byte-base64

VITE_API_BASE_URL=http://localhost/api
VITE_WS_BASE_URL=ws://localhost/ws

APP_HTTP_PORT=18080
