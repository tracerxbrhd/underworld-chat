COMPOSE_PROJECT_NAME=underworld-chat-prod

APP_HTTP_PORT=18080
APP_DOMAIN=chat.example.com

POSTGRES_DB=underworld
POSTGRES_USER=underworld
POSTGRES_PASSWORD=change-me

MINIO_ROOT_USER=underworldminio
MINIO_ROOT_PASSWORD=replace-with-a-long-minio-password
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
S3_BUCKET=underworld-files
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT=https://chat.example.com
S3_ACCESS_KEY=underworldminio
S3_SECRET_KEY=replace-with-a-long-minio-password

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=chat.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://chat.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://chat.example.com
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DATABASE_URL=postgresql://underworld:change-me@postgres:5432/underworld
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
MASTER_ENCRYPTION_KEY=replace-with-32-byte-base64

VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=/ws
