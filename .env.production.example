COMPOSE_PROJECT_NAME=underworld-chat-prod

# Dedicated Ubuntu server defaults:
# - publish the app directly on the host IP
# - open it via http://YOUR_SERVER_IP
APP_HTTP_BIND=0.0.0.0
APP_HTTP_PORT=80
APP_DOMAIN=185.68.244.224

POSTGRES_DB=underworld
POSTGRES_USER=underworld
POSTGRES_PASSWORD=change-me

MINIO_ROOT_USER=underworldminio
MINIO_ROOT_PASSWORD=replace-with-a-long-minio-password
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
S3_BUCKET=underworld-files
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT=http://185.68.244.224
S3_ACCESS_KEY=underworldminio
S3_SECRET_KEY=replace-with-a-long-minio-password

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=185.68.244.224
DJANGO_CORS_ALLOWED_ORIGINS=http://185.68.244.224
DJANGO_CSRF_TRUSTED_ORIGINS=http://185.68.244.224
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DATABASE_URL=postgresql://underworld:change-me@postgres:5432/underworld
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
MASTER_ENCRYPTION_KEY=replace-with-32-byte-base64

VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=/ws
